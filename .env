# Required environment variables for uReport NG
# Copy this file to .env.local and fill in real values before running the app.

# Auth.js v5 signing secret — REQUIRED
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# PostgreSQL connection string — REQUIRED
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# [pivota] DATABASE_URL omitted on purpose. When unset, scripts/ensure-database.js
# brings up the `db` service from docker-compose.yml and writes DATABASE_URL to
# .env.local automatically. Set it here only to point at an external database.

# Optional: session TTL in seconds (default: 28800 = 8 hours)
# AUTH_SESSION_TTL=28800
